# .env
# API base URL is optional. Leave it empty for LifeOS Local Web so the built
# frontend uses the same origin that serves the static assets.
#
# Production/local static serving:
VITE_API_BASE_URL=
#
# Advanced only: point to a dedicated API origin when serving the frontend and
# backend from different hosts.
# VITE_API_BASE_URL=http://127.0.0.1:8765

# Optional extra connect-src entries appended to the production CSP.
# Use this when the deployed frontend needs to reach additional origins, for
# example a dedicated API origin or WebSocket endpoint.
# VITE_CSP_CONNECT_SRC=https://api.example.com wss://api.example.com

VITE_ENABLE_DEBUG=true

VITE_API_TIMEOUT_MS=15000
