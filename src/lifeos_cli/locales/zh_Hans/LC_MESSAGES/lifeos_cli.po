"created_at、task_count、vision_count、event_count、people_count、\n"
"timelog_count、tag_count，以及规范化后的内容预览。"

#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:145
msgid "Use --include-deleted when reviewing soft-deleted records."
msgstr "查看软删除记录时使用 --include-deleted。"

