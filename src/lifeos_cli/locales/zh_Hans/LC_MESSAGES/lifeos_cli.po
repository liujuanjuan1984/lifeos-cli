#, python-brace-format
msgid "{noun} identifiers to delete"
msgstr "要删除的{noun}标识符"

#: src/lifeos_cli/cli_support/resources/area/parser.py:31
msgid "Manage life areas"
msgstr "管理 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:34
msgid ""
"Create and maintain high-level life areas such as work, health, or "
"relationships."
msgstr "创建并维护工作、健康、人际关系等高层 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:39
msgid ""
"Areas provide one of the top-level organizing layers for the rest of the "
"system."
msgstr "`area` 是系统其余部分的顶层组织层之一。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:50
#: src/lifeos_cli/cli_support/resources/people/parser.py:54
#: src/lifeos_cli/cli_support/resources/tag/parser.py:42
