#: src/lifeos_cli/cli_support/resources/area/parser.py:66
msgid "Create an area"
msgstr "创建 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:68
msgid "Create a new area."
msgstr "创建一个新 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:71
msgid ""
"Areas usually represent stable parts of life such as health, work, "
"family, or learning."
msgstr "`area` 通常代表生活中稳定的部分，例如健康、工作、家庭或学习。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:80
msgid "Use `--inactive` when the area should exist but not appear as active yet."
msgstr "当 `area` 应该存在但尚未显示为活动状态时，请使用 `--inactive`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:83
msgid "Area name"
msgstr "`area` 名称"

#: src/lifeos_cli/cli_support/resources/area/parser.py:84
msgid "Optional area description"
msgstr "可选 `area` 描述"

#: src/lifeos_cli/cli_support/resources/area/parser.py:85
msgid "Hex color code"
msgstr "十六进制颜色代码"

#: src/lifeos_cli/cli_support/resources/area/parser.py:86
msgid "Optional icon identifier"
msgstr "可选的图标标识符"

#: src/lifeos_cli/cli_support/resources/area/parser.py:88
msgid "Create the area as inactive"
msgstr "将 `area` 创建为非活动状态"

#: src/lifeos_cli/cli_support/resources/area/parser.py:90
#: src/lifeos_cli/cli_support/resources/task/parser.py:132
msgid "Display order"
msgstr "显示顺序"

#: src/lifeos_cli/cli_support/resources/area/parser.py:97
msgid "List areas"
msgstr "列出 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:99
msgid "List areas in display order."
msgstr "按显示顺序列出 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:102
msgid ""
"Use filters and pagination flags here instead of expecting a separate "
"search command."
msgstr "此处使用过滤器和分页标志，而不是期望单独的搜索命令。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:112
msgid "Soft-deleted areas are hidden unless `--include-deleted` is set."
msgstr "除非设置了 `--include-deleted`，否则软删除的 `area` 将被隐藏。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:113
msgid "Use `--limit` and `--offset` together for pagination."
msgstr "结合使用 `--limit` 和 `--offset` 进行分页。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:119
msgid "Include inactive areas"
msgstr "包括非活动 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:128
msgid "Show an area"
msgstr "显示 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:130
msgid "Show one area with full metadata."
msgstr "显示一个具有完整元数据的 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:133
msgid ""
"Use this action when you need exact field values instead of the compact "
"list view."
msgstr "当您需要精确的字段值而不是紧凑列表视图时，请使用此操作。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:141
msgid "Use `--include-deleted` to inspect a soft-deleted area."
msgstr "使用 `--include-deleted ` 检查软删除的 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:144
#: src/lifeos_cli/cli_support/resources/area/parser.py:167
#: src/lifeos_cli/cli_support/resources/area/parser.py:207
msgid "Area identifier"
msgstr "`area` 标识符"

#: src/lifeos_cli/cli_support/resources/area/parser.py:152
msgid "Update an area"
msgstr "更新 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:154
msgid "Update mutable area fields."
msgstr "更新可变 `area` 字段。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:156
msgid ""
"Only explicitly provided flags are changed; omitted fields stay as they "
"are."
msgstr "仅更改显式提供的标志；省略的字段保持原样。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:164
msgid "Use `--clear-description` or `--clear-icon` to remove optional values."
msgstr "使用 `--clear-description ` 或 `--clear-icon ` 删除可选值。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:168
msgid "Updated area name"
msgstr "更新的 `area` 名称"

#: src/lifeos_cli/cli_support/resources/area/parser.py:169
#: src/lifeos_cli/cli_support/resources/event/parser.py:254
#: src/lifeos_cli/cli_support/resources/people/parser.py:172
#: src/lifeos_cli/cli_support/resources/task/parser.py:358
msgid "Updated description"
msgstr "更新了描述"

#: src/lifeos_cli/cli_support/resources/area/parser.py:173
msgid "Clear the optional area description"
msgstr "清除可选的 `area` 描述"

#: src/lifeos_cli/cli_support/resources/area/parser.py:175
#: src/lifeos_cli/cli_support/resources/tag/parser.py:167
msgid "Updated hex color code"
msgstr "更新了十六进制颜色代码"

#: src/lifeos_cli/cli_support/resources/area/parser.py:176
msgid "Updated icon identifier"
msgstr "更新了图标标识符"

#: src/lifeos_cli/cli_support/resources/area/parser.py:180
msgid "Clear the optional icon identifier"
msgstr "清除可选图标标识符"

#: src/lifeos_cli/cli_support/resources/area/parser.py:186
msgid "Toggle whether the area is active"
msgstr "切换 `area` 是否处于活动状态"

#: src/lifeos_cli/cli_support/resources/area/parser.py:188
#: src/lifeos_cli/cli_support/resources/task/parser.py:374
msgid "Updated display order"
msgstr "更新了显示顺序"

#: src/lifeos_cli/cli_support/resources/area/parser.py:195
msgid "Delete an area"
msgstr "删除 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:197
msgid "Soft-delete an area."
msgstr "软删除一个 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:200
msgid ""
"The record remains in the database and can still be inspected through "
"`list --include-deleted` or `show --include-deleted`."
msgstr ""
"该记录保留在数据库中，仍然可以通过 `list --include-deleted ` 或 `show --include-deleted ` "
"检查。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:214
msgid "Run batch area operations"
msgstr "执行批量 `area` 操作"

#: src/lifeos_cli/cli_support/resources/area/parser.py:216
msgid "Run write operations that target multiple areas in one command."
msgstr "在一个命令中运行针对多个 `area` 的写入操作。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:219
msgid ""
"Use this namespace for bulk maintenance so the resource keeps a stable "
"CLI shape."
msgstr "使用此命名空间进行批量维护，以便资源保持稳定的 CLI 形状。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:233
#: src/lifeos_cli/cli_support/resources/event/parser.py:371
#: src/lifeos_cli/cli_support/resources/habit/parser.py:353
