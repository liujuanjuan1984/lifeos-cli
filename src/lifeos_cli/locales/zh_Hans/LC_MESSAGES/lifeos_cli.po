msgid "Use --limit and --offset together for pagination."
msgstr "一起使用 --limit 和 --offset 进行分页。"

#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:151
#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:193
