#: src/lifeos_cli/cli_support/resources/area/parser.py:234
#: src/lifeos_cli/cli_support/resources/people/parser.py:247
#: src/lifeos_cli/cli_support/resources/tag/parser.py:227
#: src/lifeos_cli/cli_support/resources/task/parser.py:453
#: src/lifeos_cli/cli_support/resources/vision/parser.py:314
msgid "batch_action"
msgstr "批量操作"

#: src/lifeos_cli/cli_support/resources/area/parser.py:241
msgid "Delete multiple areas"
msgstr "删除多个 `area`"

#: src/lifeos_cli/cli_support/resources/area/parser.py:242
msgid "Soft-delete multiple areas by identifier."
msgstr "通过标识符软删除多个 `area`。"

#: src/lifeos_cli/cli_support/resources/area/parser.py:243
#: src/lifeos_cli/cli_support/resources/people/parser.py:256
#: src/lifeos_cli/cli_support/resources/tag/parser.py:236
#: src/lifeos_cli/cli_support/resources/task/parser.py:462
#: src/lifeos_cli/cli_support/resources/vision/parser.py:323
msgid "Batch delete never performs hard deletion from the public CLI."
msgstr "批量删除从不从公共 CLI 执行硬删除。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:28
msgid "Run unified data import/export and batch commands"
msgstr "执行统一的数据导入/导出与批量命令"

#: src/lifeos_cli/cli_support/resources/data/parser.py:30
msgid "Run canonical data operations across LifeOS resources."
msgstr "跨 LifeOS 资源运行规范数据操作。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:33
msgid ""
"Use this namespace for machine-oriented bulk workflows such as export, "
"import, batch update, batch delete, and full bundle backup or restore."
msgstr "使用此命名空间进行面向机器的批量工作流程，例如导出、导入、批量更新、批量删除以及完整捆绑包备份或还原。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:48
msgid ""
"This namespace uses canonical JSON/JSONL snapshot rows instead of ad-hoc "
"CLI flags."
msgstr "此命名空间使用规范的 JSON/JSONL 快照行而不是临时 CLI 标志。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:52
msgid ""
"Use `export` output as the round-trip contract for later `import` or "
"`batch-update`."
msgstr "使用 `export ` 输出作为后续 `import ` 或 `batch-update ` 的往返合约。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:56
msgid ""
"Bundle import/export preserves record identifiers and relationships "
"across resources."
msgstr "捆绑导入/导出保留跨资源的记录标识符和关系。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:60
msgid ""
"Use resource-specific commands for higher-level behaviors such as "
"recurring event occurrence scopes."
msgstr "将特定于资源的命令用于更高级别的行为，例如重复 `event` 发生范围。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:63
msgid "Use `--dry-run` before applying large imports or batch changes."
msgstr "在应用大量导入或批量更改之前使用 `--dry-run`。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:76
msgid "Export one resource or a full bundle"
msgstr "导出一个资源或整个资源包"

#: src/lifeos_cli/cli_support/resources/data/parser.py:79
msgid ""
"Export canonical snapshot rows for one resource, or create a full bundle "
"zip covering all supported resources."
msgstr "导出一个资源的规范快照行，或创建涵盖所有支持资源的完整捆绑包 zip。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:83
msgid "Bundle export is implied when the target is `all`."
msgstr "当目标是 `all ` 时，暗示捆绑导出。"

#: src/lifeos_cli/cli_support/resources/data/parser.py:97
msgid "Export format for one resource; bundle is implied for `all`"
msgstr "一项资源的导出格式；`all` 隐含捆绑包"

#: src/lifeos_cli/cli_support/resources/data/parser.py:100
msgid "Write exported data to a file instead of stdout"
msgstr "将导出的数据写入文件而不是 stdout"

#: src/lifeos_cli/cli_support/resources/data/parser.py:105
msgid "Exclude soft-deleted rows from exported snapshots"
msgstr "从导出的快照中排除软删除的行"

#: src/lifeos_cli/cli_support/resources/data/parser.py:113
msgid "Import one resource or a full bundle"
msgstr "导入一个资源或整个资源包"

#: src/lifeos_cli/cli_support/resources/data/parser.py:116
msgid ""
"Import canonical snapshot rows for one resource, or restore a full bundle"
" zip containing multiple resources."
