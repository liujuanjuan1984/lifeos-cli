msgstr "重复以使用一个或多个标识符替换 `event`"

#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:317
msgid "Remove all linked events"
msgstr "移除所有关联的 `event`"

#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:325
msgid "Repeat to replace timelogs with one or more identifiers"
msgstr "重复以将 `timelog` 替换为一个或多个标识符"

#: src/lifeos_cli/cli_support/resources/note/parser_actions.py:330
