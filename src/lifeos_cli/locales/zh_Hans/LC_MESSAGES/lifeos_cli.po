#: src/lifeos_cli/cli_support/help_utils.py:27
msgid "Examples"
msgstr "示例"

#: src/lifeos_cli/cli_support/help_utils.py:30
msgid "Notes"
msgstr "说明"

#: src/lifeos_cli/cli_support/parser.py:50
msgid "Run LifeOS resource commands from the terminal."
msgstr "在终端中运行 LifeOS 资源命令。"

#: src/lifeos_cli/cli_support/parser.py:52
msgid "Command grammar:"
msgstr "命令语法："

#: src/lifeos_cli/cli_support/parser.py:55
msgid "Resources model domains such as areas, people, visions, tasks, and notes."
msgstr "`area`、`people`、`vision`、`task`、`note` 等资源模型域。"

#: src/lifeos_cli/cli_support/parser.py:58
msgid ""
"Time-oriented domains use `event` for planned schedule blocks and "
"`timelog` for actual time records."
msgstr "时间相关资源中，`event` 用于计划中的时间块，`timelog` 用于记录实际发生的用时。"

#: src/lifeos_cli/cli_support/parser.py:62
msgid "Use `schedule` for aggregated day and range views across planned work."
msgstr "使用 `schedule` 查看跨计划工作的按日或区间聚合视图。"

#: src/lifeos_cli/cli_support/parser.py:64
msgid "Habits and habit actions are exposed as separate top-level resources."
msgstr "`habit` 和 `habit-action` 作为独立的顶层资源提供。"

#: src/lifeos_cli/cli_support/parser.py:66
msgid "System commands such as init, config, and db manage runtime setup."
msgstr "init、config 和 db 等系统命令管理运行时设置。"

#: src/lifeos_cli/cli_support/parser.py:68
msgid ""
"Use `data` for canonical import/export, bundle backup, and batch "
"operations."
msgstr "使用 `data` 执行规范的导入导出、bundle 备份和批量操作。"

#: src/lifeos_cli/cli_support/parser.py:70
msgid "Actions are short verbs that operate on records or runtime state."
msgstr "动作是对记录或运行时状态进行操作的简短动词。"

#: src/lifeos_cli/cli_support/parser.py:95
msgid ""
"Prefer short, stable resource names so new command families stay "
"consistent."
msgstr "优先使用简短且稳定的资源名称，保持新命令族的一致性。"

#: src/lifeos_cli/cli_support/parser.py:97
msgid ""
"Use natural exceptions such as `people` when they are clearer than forced"
" regular forms."
msgstr "当 `people` 这类自然例外形式比强制套用规则更清晰时，优先使用它们。"

#: src/lifeos_cli/cli_support/parser.py:100
msgid "Prefer short action verbs such as add, list, update, and delete."
msgstr "优先使用简短的动作动词，例如 `add`、`list`、`update` 和 `delete`。"

#: src/lifeos_cli/cli_support/parser.py:102
msgid ""
"For structured resources, prefer `list` with filters and pagination over "
"separate query verbs."
msgstr "对于结构化资源，优先使用带过滤与分页参数的 `list`，而不是另设查询动词。"

#: src/lifeos_cli/cli_support/parser.py:106
msgid ""
"Use sub-namespaces such as `batch` when a resource needs grouped bulk "
"operations."
msgstr "当资源需要成组的批量操作时，使用 `batch` 等子命名空间。"

#: src/lifeos_cli/cli_support/parser.py:110
msgid ""
"Use `lifeos <resource> --help` and `lifeos <resource> <action> --help` as"
" the primary command reference."
msgstr ""
"将 `lifeos <resource> --help` 和 `lifeos <resource> <action> --help` "
"作为主要命令参考。"

#: src/lifeos_cli/cli_support/parser.py:113
msgid "Each resource help page should explain scope, actions, and examples."
msgstr "每个资源帮助页面都应解释范围、操作和示例。"

#: src/lifeos_cli/cli_support/parser.py:115
msgid ""
"When automation acts on behalf of a human, model the acting subject "
"explicitly through `people` and repeated `--person-id` flags."
msgstr "当自动化代表人类执行操作时，应通过 `people` 和重复的 `--person-id` 参数显式建模执行主体。"

#: src/lifeos_cli/cli_support/parser.py:119
msgid ""
"Agents that create records for a human should run `lifeos config show` "
"and use the effective preference language for titles, descriptions, and "
"note content unless the human explicitly asks for another language."
msgstr ""
"当代理为人类创建记录时，应先运行 `lifeos config show`，并使用当前生效的语言偏好来编写标题、描述和 `note` "
"内容，除非人类明确要求使用其他语言。"

#: src/lifeos_cli/cli_support/parser.py:123
msgid "Keep human-only work, agent-only work, and truly shared work distinct."
msgstr "区分仅由人类参与的工作、仅由代理参与的工作和真正共享的工作。"

#: src/lifeos_cli/cli_support/parser.py:124
msgid "Run `lifeos init` before using database-backed resource commands."
msgstr "在使用依赖数据库的资源命令前，请先运行 `lifeos init`。"

#: src/lifeos_cli/cli_support/parser.py:133
msgid "Show the program version and exit"
msgstr "显示程序版本并退出"

#: src/lifeos_cli/cli_support/parser.py:137
msgid "resources"
msgstr "资源"

#: src/lifeos_cli/cli_support/parser.py:138
msgid "resource"
msgstr "资源"

